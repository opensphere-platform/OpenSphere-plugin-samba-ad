{
  "manifestVersion": 3,
  "kind": "plugin",
  "id": "samba-ad",
  "hostRef": "foundation",
  "hostApiVersion": "1.0.0",
  "hostCompat": ">=1.0.0 <2.0.0",
  "version": "0.1.1-edge.6",
  "title": "Samba-AD",
  "description": "Workspace directory management plugin mounted inside Foundation.",
  "entry": "ui-shell.plugin.js",
  "entrySha256": "03d5667ae1e177b22c98a6ce82493fc83a2f0ae45ecdf20328f2329c4184b8dd",
  "shellCompat": ">=0.2.0 <0.9.0",
  "sdkVersion": "0.3.6",
  "permissions": [
    "api:proxy",
    "manual:contribute"
  ],
  "nav": {
    "band": "운영 Operate",
    "label": "Samba-AD"
  },
  "designSystem": "clarity",
  "apiBase": "/api/plugins/samba-ad",
  "renderMode": "esm",
  "contributions": {
    "page": {
      "enabled": false,
      "reason": "Mounted inside the Foundation subShell"
    },
    "navigation": {
      "enabled": false,
      "mode": "none",
      "reason": "Foundation owns the child navigation"
    },
    "api": {
      "enabled": true,
      "basePath": "/api/plugins/foundation"
    },
    "cli": {
      "enabled": true,
      "namespace": "ad",
      "manifestPath": "/cli/manifest"
    },
    "manual": {
      "enabled": true,
      "sourceId": "plugin:samba-ad",
      "mode": "runtime"
    },
    "search": {
      "enabled": true,
      "mode": "index"
    },
    "notification": {
      "enabled": true,
      "frontend": false,
      "backend": true
    },
    "observability": {
      "enabled": true,
      "logs": true,
      "metrics": true,
      "traces": false
    }
  }
}
